ANTHROPIC_API_KEY=your_anthropic_api_key_here
# PostgreSQL connection string — Railway provides this automatically as DATABASE_URL
DATABASE_URL=postgresql://user:password@host:5432/dbname
JWT_SECRET=change_this_to_a_long_random_secret
PORT=3001
USDA_API_KEY=your_usda_api_key_here

# Google Fit Integration
# Setup: https://console.cloud.google.com → Fitness API → OAuth 2.0 credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-railway-app.railway.app/api/integrations/google/callback

# Frontend URL (used to redirect after OAuth and for CORS)
FRONTEND_URL=https://nutriai-lime.vercel.app
